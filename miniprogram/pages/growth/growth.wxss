/* 全局样式：默认支持上下滚动，内容超出自动滑动 */
page {
  background-color: #F9FBF8;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}
.container {
  padding: 0 30rpx;
  padding-bottom: 120rpx; /* 给底部tabbar留空间，确保滑动到底部不被遮挡 */
}

/* 1. 顶部标题栏 */
.header {
  background: linear-gradient(135deg, #ffb6c1 0%, #ffe4e1 100%);
  margin: 0 -30rpx;
  padding: 40rpx 30rpx;
  border-radius: 0 0 40rpx 40rpx;
  margin-bottom: 30rpx;
}
.header .title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

/* 2. 成长数据卡片 */
.growth-data-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}
.data-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}
.data-header .title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}
.update-time {
  font-size: 26rpx;
  color: #999;
}
.data-grid {
  display: flex;
  justify-content: space-between;
  margin-bottom: 40rpx;
}
.data-item {
  text-align: center;
  width: 30%;
}
.data-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #ff6b81;
  display: inline-block;
}
.data-unit {
  font-size: 28rpx;
  color: #ff6b81;
  margin-left: 4rpx;
}
.data-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin: 8rpx 0;
}
.data-change {
  font-size: 24rpx;
  color: #52c41a;
}
.data-change.normal {
  color: #666;
}

/* 月龄进度条 */
.progress-bar {
  width: 100%;
}
.progress-bg {
  height: 20rpx;
  background: #f2f2f2;
  border-radius: 10rpx;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #ffb6c1 0%, #ff8fab 100%);
  width: 70%; /* 模拟8个月进度 */
}
.progress-labels {
  display: flex;
  justify-content: space-between;
  margin-top: 8rpx;
}
.progress-labels text {
  font-size: 24rpx;
  color: #999;
}

/* 3. 功能按钮区 */
.action-grid {
  display: flex;
  justify-content: space-between;
  margin-bottom: 40rpx;
}
.action-item {
  background: #fff;
  border-radius: 20rpx;
  width: 22%;
  padding: 30rpx 10rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}
.action-icon {
  font-size: 40rpx;
  margin-bottom: 16rpx;
}
.action-text {
  font-size: 26rpx;
  color: #333;
}

/* 4. 发育里程碑 */
.milestone-section {
  margin-bottom: 40rpx;
}
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}
.milestone-list {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}
.milestone-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f2f2f2;
}
.milestone-item:last-child {
  border-bottom: none;
}
.milestone-status {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  font-size: 24rpx;
}
.milestone-status.done {
  background: #52c41a;
  color: #fff;
}
.milestone-status.pending {
  border: 2rpx solid #ccc;
  color: #ccc;
}
.milestone-info {
  flex: 1;
}
.milestone-name {
  display: block;
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
}
.milestone-time {
  font-size: 26rpx;
  color: #999;
}

/* 5. 疫苗提醒模块 */
.vaccine-section {
  margin-bottom: 30rpx;
}
.vaccine-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}
.vaccine-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}
.vaccine-info {
  flex: 1;
}
.vaccine-name {
  display: block;
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
}
.vaccine-time {
  font-size: 26rpx;
  color: #999;
}
.vaccine-btn {
  background: #ff6b81;
  color: #fff;
  font-size: 26rpx;
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
}
