<!-- 成长记录页面 -->
<view class="container">
  <!-- 1. 顶部标题栏 -->
  <view class="header">
    <text class="title">成长记录</text>
  </view>

  <!-- 2. 成长数据模块 -->
  <view class="growth-data-card">
    <view class="data-header">
      <text class="title">成长数据</text>
      <text class="update-time">更新于今天</text>
    </view>
    <view class="data-grid">
      <view class="data-item">
        <text class="data-value">72.5</text>
        <text class="data-unit">cm</text>
        <text class="data-label">身高</text>
        <text class="data-change">+2.5cm</text>
      </view>
      <view class="data-item">
        <text class="data-value">9.2</text>
        <text class="data-unit">kg</text>
        <text class="data-label">体重</text>
        <text class="data-change">+0.3kg</text>
      </view>
      <view class="data-item">
        <text class="data-value">44</text>
        <text class="data-unit">cm</text>
        <text class="data-label">头围</text>
        <text class="data-change normal">正常</text>
      </view>
    </view>
    <!-- 月龄进度条 -->
    <view class="progress-bar">
      <view class="progress-bg">
        <view class="progress-fill"></view>
      </view>
      <view class="progress-labels">
        <text>6月</text>
        <text>7月</text>
        <text>8月</text>
      </view>
    </view>
  </view>

  <!-- 3. 功能按钮区 -->
  <view class="action-grid">
    <view class="action-item" bindtap="goRecordData">
      <view class="action-icon">📝</view>
      <text class="action-text">记录数据</text>
    </view>
    <view class="action-item" bindtap="goVaccineRemind">
      <view class="action-icon">💉</view>
      <text class="action-text">疫苗提醒</text>
    </view>
    <view class="action-item" bindtap="goGrowthEval">
      <view class="action-icon">🎯</view>
      <text class="action-text">发育评估</text>
    </view>
    <view class="action-item" bindtap="goGrowthAlbum">
      <view class="action-icon">📷</view>
      <text class="action-text">成长相册</text>
    </view>
  </view>

  <!-- 4. 发育里程碑 -->
  <view class="milestone-section">
    <text class="section-title">发育里程碑</text>
    <view class="milestone-list">
      <view class="milestone-item">
        <view class="milestone-status done">✓</view>
        <view class="milestone-info">
          <text class="milestone-name">独坐稳固</text>
          <text class="milestone-time">7个月达成</text>
        </view>
      </view>
      <view class="milestone-item">
        <view class="milestone-status done">✓</view>
        <view class="milestone-info">
          <text class="milestone-name">爬行</text>
          <text class="milestone-time">7个半月达成</text>
        </view>
      </view>
      <view class="milestone-item">
        <view class="milestone-status pending">○</view>
        <view class="milestone-info">
          <text class="milestone-name">扶站</text>
          <text class="milestone-time">预计8-9个月</text>
        </view>
      </view>
      <view class="milestone-item">
        <view class="milestone-status pending">○</view>
        <view class="milestone-info">
          <text class="milestone-name">叫爸爸妈妈</text>
          <text class="milestone-time">预计9-10个月</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 5. 疫苗提醒模块 -->
  <view class="vaccine-section">
    <text class="section-title">疫苗提醒</text>
    <view class="vaccine-card">
      <view class="vaccine-icon">💉</view>
      <view class="vaccine-info">
        <text class="vaccine-name">麻腮风疫苗</text>
        <text class="vaccine-time">接种时间：4月15日</text>
      </view>
      <view class="vaccine-btn" bindtap="goVaccineDetail">
        <text>查看详情</text>
      </view>
    </view>
  </view>
</view>