.container{padding:20rpx;background:#f7f8fa}
.card{background:#fff;border-radius:24rpx;padding:30rpx;margin-bottom:24rpx}
.tit{font-size:32rpx;font-weight:bold;margin-bottom:24rpx}
.row{margin-bottom:24rpx}
.row text{display:block;margin-bottom:12rpx;color:#666}
.picker{border:1rpx solid #eee;border-radius:16rpx;padding:24rpx}
.checkbox{display:flex;justify-content:space-between;align-items:center}
.save-btn{background:#52c41a;color:#fff;border-radius:16rpx;padding:24rpx}
.item{display:flex;justify-content:space-between;align-items:center;padding:16rpx 0;border-bottom:1rpx solid #f2f2f2}
.tag{background:#fff1f0;color:#ff4d4f;padding:6rpx 12rpx;border-radius:8rpx}