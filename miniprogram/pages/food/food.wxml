<!-- 辅食记录页面 -->
<view class="container">
  <!-- 1. 顶部标题栏 -->
  <view class="header">
    <text class="title">辅食记录</text>
  </view>

  <!-- 2. 月龄标签切换 -->
  <view class="age-tabs">
    <view 
      wx:for="{{ageTabs}}" 
      wx:key="id" 
      class="tab-item {{currentTab === item.id ? 'active' : ''}}"
      bindtap="switchTab"
      data-id="{{item.id}}"
    >
      <text class="tab-text">{{item.name}}</text>
    </view>
  </view>

  <!-- 3. 今日辅食记录 -->
  <view class="record-section">
    <text class="section-title">今日辅食记录</text>
    <view class="record-list">
      <view wx:for="{{todayRecord}}" wx:key="id" class="record-item">
        <view class="time">{{item.time}}</view>
        <view class="food-info">
          <text class="food-name">{{item.name}}</text>
          <text class="food-amount">{{item.amount}}</text>
        </view>
        <view class="digest-status">{{item.digest}}</view>
      </view>
    </view>
  </view>

  <!-- 4. 适合月龄的辅食推荐 -->
  <view class="recommend-section">
    <text class="section-title">适合{{currentAge}}月龄的辅食</text>
    <view class="recommend-list">
      <view wx:for="{{recommendFood}}" wx:key="id" class="food-card">
        <view class="food-icon">{{item.icon}}</view>
        <view class="food-detail">
          <text class="food-name">{{item.name}}</text>
          <text class="food-desc">{{item.desc}}</text>
        </view>
        <view class="food-tag">{{item.tag}}</view>
      </view>
    </view>
  </view>
</view>