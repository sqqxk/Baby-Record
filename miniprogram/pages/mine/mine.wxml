<!-- 我的页面 -->
<view class="container">
  <!-- 1. 顶部标题栏 -->
  <view class="header">
    <text class="title">我的</text>
  </view>

 <!-- 2. 宝宝信息卡片 -->
<view class="baby-card">
  <view class="baby-info">
    <view class="avatar">👶</view>
    <view class="info-text">
      <!-- 修复：分开写text标签，去掉?.，用||兜底空值 -->
      <text class="name">{{currentBaby.name || '小宝贝'}}</text>
      <text class="gender-age">
        {{currentBaby.gender || '男宝'}}·{{currentBaby.month || 8}}个月{{currentBaby.day || 12}}天
      </text>
    </view>
  </view>
  <view class="edit-btn" bindtap="goEditBaby">编辑</view>
</view>

  <!-- 3. 功能列表 -->
  <view class="func-list">
    <view class="func-item" bindtap="goCollection">
      <view class="func-icon star">⭐</view>
      <text class="func-text">我的收藏</text>
      <view class="arrow">></view>
    </view>
    <view class="func-item" bindtap="goBabyNote">
      <view class="func-icon note">📒</view>
      <text class="func-text">育儿笔记</text>
      <view class="arrow">></view>
    </view>
    <view class="func-item" bindtap="goExportRecord">
      <view class="func-icon export">📤</view>
      <text class="func-text">导出记录</text>
      <view class="arrow">></view>
    </view>
    <view class="func-item" bindtap="goNoticeSetting">
      <view class="func-icon notice">🔔</view>
      <text class="func-text">通知设置</text>
      <view class="arrow">></view>
    </view>
    <view class="func-item" bindtap="goPrivacySetting">
      <view class="func-icon privacy">🔒</view>
      <text class="func-text">隐私设置</text>
      <view class="arrow">></view>
    </view>
    <view class="func-item" bindtap="goHelpFeedback">
      <view class="func-icon help">❓</view>
      <text class="func-text">帮助与反馈</text>
      <view class="arrow">></view>
    </view>
    <view class="func-item" bindtap="goAboutUs">
      <view class="func-icon about">ℹ️</view>
      <text class="func-text">关于我们</text>
      <view class="arrow">></view>
    </view>
  </view>

  <!-- 4. 多宝宝管理模块（保留核心功能） -->
 <!-- 4. 多宝宝管理模块（保留核心功能） -->
<view class="baby-manage-section">
  <view class="manage-header">
    <text class="title">宝宝管理</text>
    <view class="add-btn" bindtap="goAddBaby">+添加宝宝</view>
  </view>
  <!-- 宝宝列表 -->
  <view class="baby-list">
    <view 
      wx:for="{{babyList}}" 
      wx:key="id" 
      class="baby-item {{item.id === currentBabyId ? 'active' : ''}}"
      bindtap="switchBaby"
      data-id="{{item.id}}"
    >
      <view class="baby-avatar">👶</view>
      <text class="baby-name">{{item.name}}</text>
      <text class="baby-age">{{item.month}}月龄</text>
    </view>
  </view>
  <!-- 当前选中宝宝（修复语法错误） -->
  <view class="current-baby">
    <text class="label">当前：</text>
    <!-- 关键修复：一个text标签写完整逻辑，去掉?.，兜底默认值 -->
    <text class="current-name">{{currentBaby.name || '宝宝'}}·{{currentBaby.month || 6}}月龄</text>
    <view class="edit-manage-btn" bindtap="goEditBaby">编辑</view>
  </view>
</view>

  <!-- 5. 育儿工具（占位，保留布局） -->
  <view class="tools-section">
    <text class="section-title">育儿工具</text>
    <view class="tools-grid">
      <view class="tool-item">
        <view class="tool-icon">🧮</view>
        <text class="tool-text">辅食计算器</text>
      </view>
      <view class="tool-item">
        <view class="tool-icon">📅</view>
        <text class="tool-text">疫苗时间表</text>
      </view>
      <view class="tool-item">
        <view class="tool-icon">📝</view>
        <text class="tool-text">成长曲线</text>
      </view>
    </view>
  </view>
</view>