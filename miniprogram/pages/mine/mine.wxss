/* 全局样式 严格遵循UI规范 */
.container {
  background-color: #F9FBF8;
  padding: 20rpx;
  min-height: 100vh;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

/* 宝宝管理模块 */
.baby-card {
  position: relative;
}
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}
.add-btn {
  font-size: 26rpx;
  color: #52c41a;
  background: none;
  border: none;
  padding: 0;
}
.baby-scroll {
  white-space: nowrap;
  margin-bottom: 20rpx;
}
.baby-item {
  display: inline-block;
  text-align: center;
  margin-right: 24rpx;
  padding: 16rpx;
  border-radius: 16rpx;
  border: 2rpx solid #eee;
  width: 120rpx;
}
.baby-item.active {
  border-color: #52c41a;
  background: #F9FBF8;
}
.baby-avatar {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}
.baby-name {
  font-size: 26rpx;
  color: #333;
}
.baby-month {
  font-size: 22rpx;
  color: #999;
}
.current-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}
.edit-btn {
  color: #409eff;
  background: none;
  border: none;
  font-size: 24rpx;
}

/* 会员中心 */
.vip-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.vip-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.vip-icon {
  font-size: 40rpx;
}
.vip-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}
.vip-desc {
  font-size: 24rpx;
  color: #999;
}
.vip-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.vip-tag {
  color: #ff4d4f;
  font-size: 24rpx;
}

/* 菜单通用 */
.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f2f2f2;
  font-size: 28rpx;
  color: #333;
}
.menu-item:last-child {
  border-bottom: none;
}
.menu-icon {
  font-size: 32rpx;
  margin-right: 20rpx;
  width: 48rpx;
  text-align: center;
}
.arrow {
  margin-left: auto;
  color: #999;
  font-size: 32rpx;
}

/* 版本号 */
.version {
  text-align: center;
  color: #999;
  font-size: 24rpx;
  margin: 40rpx 0;
}