.container{padding:20rpx;background:#f7f8fa;min-height:100vh}
.card{background:#fff;border-radius:24rpx;padding:30rpx;margin-bottom:24rpx}
.tit{font-size:32rpx;font-weight:bold;margin-bottom:20rpx}
.info{color:#666;margin:8rpx 0;font-size:28rpx}
.btn-box{display:flex;gap:20rpx;margin:20rpx 0}
.btn{flex:1;padding:24rpx;border-radius:16rpx;color:#fff;font-size:28rpx}
.green{background:#52c41a}
.blue{background:#409eff}
.item{padding:16rpx 0;border-bottom:1rpx solid #f2f2f2}
.empty{color:#999;padding:20rpx 0}